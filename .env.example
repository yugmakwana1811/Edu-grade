# PostgreSQL connection string (Neon, Supabase, Railway, or another managed Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/edugrade?sslmode=require"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Required in production for private assignment, resource, and answer-page storage
BLOB_READ_WRITE_TOKEN=""

# Optional: server-only OpenRouter credential. Never prefix this with NEXT_PUBLIC_.
# The model is locked in server code to nvidia/nemotron-3-ultra-550b-a55b:free.
# Without a key, deterministic teaching-safe templates are used.
OPENROUTER_API_KEY=""

# Recommended for stable Server Action references across rolling deployments.
# Generate a 32-byte base64 key and keep the same value across instances.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""
